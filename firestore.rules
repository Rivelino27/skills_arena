rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    /// True when the requesting user has `isAdmin: true` in their user
    /// document. Admins can flip the `isVerified` flag on venues / users.
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid))
            .data.get('isAdmin', false) == true;
    }

    /// True when the requesting user has `isPremium: true` OR is an admin.
    /// Used to gate the "Times" feature (create / manage).
    function isPremium() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid))
            .data.get('isPremium', false) == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid))
            .data.get('isAdmin', false) == true
        );
    }

    /// Helper used by team_matches rules. Returns the data of a team doc
    /// so we can check captain / member status of the proposer/opponent.
    function teamDoc(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)).data;
    }

    // в”Ђв”Ђ Users в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // The user owns their own document, BUT:
    //   - `isAdmin`, `isPremium`, `isVerified` cannot be set by the client.
    //     They must be promoted out-of-band (Firebase console or Cloud
    //     Function), or by an admin via the in-app toggle. Otherwise any
    //     signed-in user could grant themselves admin or premium roles.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isMe(uid)
        && request.resource.data.get('isAdmin', false) == false
        && request.resource.data.get('isPremium', false) == false
        && request.resource.data.get('isVerified', false) == false;
      // The user can update their own document, but cannot promote
      // themselves to admin/premium/verified вЂ” those flags must stay
      // unchanged unless an admin is doing the write.
      allow update: if (
        isMe(uid)
        && request.resource.data.get('isAdmin', false)
            == resource.data.get('isAdmin', false)
        && request.resource.data.get('isPremium', false)
            == resource.data.get('isPremium', false)
        && request.resource.data.get('isVerified', false)
            == resource.data.get('isVerified', false)
      ) || (
        // Admins can flip flags on any user.
        isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isAdmin', 'isPremium', 'isVerified'])
      ) || (
        // Anyone signed-in can toggle following on someone else's doc, but
        // only the followersCount + following counter mirror вЂ” used by
        // SocialRepository.toggleFollow. The actor's UID must be in (or
        // removed from) the `following` list, never the target's.
        isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['followersCount'])
      );
      allow delete: if false;
    }

    // в”Ђв”Ђ Sports venues (quadras) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // Field: `addedBy` (not `createdBy`).
    // Any signed-in user may patch the live occupancy fields (occupancy,
    // occupancyUpdatedAt, occupancyUpdatedBy). All other fields are author-only.
    match /sports_venues/{venueId} {
      allow read: if isSignedIn();
      // Creator cannot self-mark as verified.
      allow create: if isSignedIn()
        && request.resource.data.addedBy == request.auth.uid
        && request.resource.data.get('isVerified', false) == false;
      allow update: if isSignedIn() && (
        // Author can update most fields, but cannot flip `isVerified`.
        (
          resource.data.addedBy == request.auth.uid
          && request.resource.data.get('isVerified', false)
              == resource.data.get('isVerified', false)
        )
        // Anyone signed-in can patch occupancy fields.
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['occupancy', 'occupancyUpdatedAt', 'occupancyUpdatedBy'])
          && request.resource.data.occupancyUpdatedBy == request.auth.uid
        )
        // Only admins can flip the verified flag.
        || (
          isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isVerified', 'verifiedBy', 'verifiedAt'])
        )
      );
      allow delete: if isSignedIn() && resource.data.addedBy == request.auth.uid;

      // в”Ђв”Ђ Visitantes (check-in / hall da fama) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // Cada usuГЎrio tem um doc prГіprio com seu UID. Spam-protect (4h)
      // Г© feito no client; aqui sГі garantimos identidade.
      match /visitors/{userId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.userId == userId;
        allow delete: if false;
      }
    }

    // в”Ђв”Ђ Player availability в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // Field: `userId`
    match /player_availability/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // в”Ђв”Ђ Venue attendance (quem vai jogar onde / quando) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // Field: `userId` (the attendee)
    match /venue_attendance/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // в”Ђв”Ђ Posts в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // Field: `userId` (post author).
    // Anyone signed-in can update `likedBy`, `likesCount`, `commentsCount`
    // (used by toggleLike + addComment). Other fields are author-only.
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likedBy', 'likesCount', 'commentsCount'])
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Comments вЂ” field: `userId`. Replies usam os mesmos docs com
      // `replyToId` / `replyToName` opcionais.
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    // в”Ђв”Ђ Chats в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // Field: `participants` (list of UIDs).
    // `resource == null` lets `getOrCreateConversation` probe before creating.
    // Venue-slot group chats (`isVenueSlotGroup: true`) are public-join: any
    // signed-in user can create with size>=1 or join an existing one.
    match /chats/{chatId} {
      allow get: if isSignedIn() && (
        resource == null || request.auth.uid in resource.data.participants
      );
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      // size() >= 2 supports both 1-1 chats and N-party group chats.
      // Venue-slot groups are an exception: created with the first attendee.
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && (
          request.resource.data.participants.size() >= 2
          || request.resource.data.get('isVenueSlotGroup', false) == true
        );
      // Non-participants can only update venue-slot groups, and only to
      // ADD themselves to participants (not to modify other fields, not
      // to remove anyone). Once they're a participant, the first branch
      // allows full updates (e.g., lastMessage, lastReadAt, etc.).
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.participants
        || (
          resource.data.get('isVenueSlotGroup', false) == true
          && request.auth.uid in request.resource.data.participants
          && request.resource.data.participants
              .hasAll(resource.data.participants)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['participants', 'participantNames', 'participantPhotos'])
        )
      );
      allow delete: if false;

      // Messages вЂ” field: `senderId`
      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid;
        // Allow update so future read-receipts / reactions can patch the message;
        // only the sender or another participant can patch.
        allow update: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow delete: if false;
      }
    }

    // в”Ђв”Ђ Teams (premium) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // Captain (= request.auth.uid) creates the team and is the only one
    // who can edit its core fields. Membros podem se auto-remover
    // (atualizaГ§ГЈo limitada que sГі encolhe `memberIds`/`members`).
    match /teams/{teamId} {
      allow read: if isSignedIn();

      // Criar exige plano premium (ou admin) e ser o prГіprio capitГЈo.
      allow create: if isSignedIn()
        && request.resource.data.captainId == request.auth.uid
        && request.resource.data.memberIds.hasAll([request.auth.uid])
        && isPremium();

      // CapitГЈo pode tudo. NГЈo-capitГЈo sГі pode se auto-remover:
      // memberIds[i] saiu, member objects shrink, e nenhum outro campo muda.
      allow update: if isSignedIn() && (
        resource.data.captainId == request.auth.uid
        || (
          request.auth.uid in resource.data.memberIds
          && !(request.auth.uid in request.resource.data.memberIds)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['members', 'memberIds'])
        )
      );

      allow delete: if isSignedIn()
        && resource.data.captainId == request.auth.uid;
    }

    // в”Ђв”Ђ Desafios entre times в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // Quem propГµe precisa ser membro do time1. Quem altera status precisa
    // ser capitГЈo de algum dos dois times (aceitar, recusar, cancelar).
    match /team_matches/{matchId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in teamDoc(request.resource.data.team1Id).memberIds
        && request.resource.data.teamIds.hasAll([
              request.resource.data.team1Id,
              request.resource.data.team2Id
           ]);

      // SГі capitГЈes dos dois times podem mexer no status (accept / decline /
      // cancel). NГЈo permite trocar IDs nem datas вЂ” apenas o campo `status`.
      allow update: if isSignedIn()
        && (
          request.auth.uid == teamDoc(resource.data.team1Id).captainId
          || request.auth.uid == teamDoc(resource.data.team2Id).captainId
        )
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status']);

      allow delete: if false; // matches ficam pro histГіrico
    }
  }
}
