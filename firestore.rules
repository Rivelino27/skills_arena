rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isMe(uid);
      allow delete: if false;
    }

    // ── Sports venues (quadras) ───────────────────────────────────────────
    // Field: `addedBy` (not `createdBy`).
    // Any signed-in user may patch the live occupancy fields (occupancy,
    // occupancyUpdatedAt, occupancyUpdatedBy). All other fields are author-only.
    match /sports_venues/{venueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.addedBy == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.addedBy == request.auth.uid
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['occupancy', 'occupancyUpdatedAt', 'occupancyUpdatedBy'])
          && request.resource.data.occupancyUpdatedBy == request.auth.uid
        )
      );
      allow delete: if isSignedIn() && resource.data.addedBy == request.auth.uid;
    }

    // ── Player availability ───────────────────────────────────────────────
    // Field: `userId`
    match /player_availability/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── Posts ─────────────────────────────────────────────────────────────
    // Field: `userId` (post author).
    // Anyone signed-in can update `likedBy`, `likesCount`, `commentsCount`
    // (used by toggleLike + addComment). Other fields are author-only.
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likedBy', 'likesCount', 'commentsCount'])
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Comments — field: `userId`
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    // ── Chats ─────────────────────────────────────────────────────────────
    // Field: `participants` (list of two UIDs).
    // `resource == null` lets `getOrCreateConversation` probe before creating.
    match /chats/{chatId} {
      allow get: if isSignedIn() && (
        resource == null || request.auth.uid in resource.data.participants
      );
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      // size() >= 2 supports both 1-1 chats and N-party group chats.
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() >= 2;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow delete: if false;

      // Messages — field: `senderId`
      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid;
        // Allow update so future read-receipts / reactions can patch the message;
        // only the sender or another participant can patch.
        allow update: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow delete: if false;
      }
    }
  }
}
